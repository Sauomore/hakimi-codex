/* Hakimi Codex - Claude Code style theme */

Screen {
    background: #0d1117;
}

MainScreen {
    layout: vertical;
    width: 100%;
    height: 100%;
    background: #0d1117;
}

#status_bar {
    height: 1;
    background: #161b22;
    color: #8b949e;
    padding: 0 2;
}

#messages_container {
    height: 1fr;
    background: #0d1117;
    border: none;
}

#input_container {
    height: auto;
    background: #161b22;
    border-top: solid #30363d;
    padding: 0 1;
}

#input_container Input {
    height: auto;
    min-height: 1;
    background: #0d1117;
    color: #e6edf3;
    border: none;
    padding: 0 1;
}

#input_container Input:focus {
    border: none;
}

#input_hint {
    height: 1;
    color: #484f58;
    padding: 0 2;
}

.user-msg {
    height: auto;
    padding: 0 2;
    margin: 1 0;
    color: #58a6ff;
}

.ai-msg {
    height: auto;
    padding: 0 2;
    margin: 1 0;
    color: #e6edf3;
}

.system-msg {
    height: auto;
    padding: 0 2;
    margin: 0;
    color: #484f58;
}

.tool-msg {
    height: auto;
    padding: 0 2;
    margin: 0;
    color: #8b949e;
    background: #161b22;
    border-left: solid #30363d;
}

.diff-block {
    height: auto;
    margin: 1 0;
    padding: 0;
}

.diff-header {
    height: 1;
    background: #161b22;
    color: #e6edf3;
    padding: 0 2;
}

.diff-line-added {
    height: auto;
    color: #3fb950;
    background: #0f2d1f;
    padding: 0 2;
}

.diff-line-removed {
    height: auto;
    color: #f85149;
    background: #3d1010;
    padding: 0 2;
}

.diff-line-context {
    height: auto;
    color: #8b949e;
    padding: 0 2;
}

.code-block {
    height: auto;
    margin: 1 0;
    background: #161b22;
    border: solid #30363d;
}

.code-header {
    height: 1;
    background: #21262d;
    color: #8b949e;
    padding: 0 2;
}

.code-content {
    height: auto;
    padding: 0 2;
    color: #e6edf3;
}

.tool-call {
    height: auto;
    margin: 1 0;
    background: #161b22;
    border-left: solid #58a6ff;
}

.tool-call-header {
    height: 1;
    color: #58a6ff;
    padding: 0 2;
}

.tool-call-content {
    height: auto;
    padding: 0 2;
    color: #8b949e;
}

ModelEditDialog {
    align: center middle;
    background: #0d1117 80%;
}

ModelEditDialog > Container {
    width: 80;
    height: auto;
    border: solid #30363d;
    background: #161b22;
    padding: 1 2;
}

ModelEditDialog Container > Static.title {
    text-align: center;
    color: #58a6ff;
    height: 1;
    margin-bottom: 1;
}

ModelEditDialog Container > Input {
    margin: 1 0;
    background: #0d1117;
    color: #e6edf3;
    border: solid #30363d;
}

ModelEditDialog Container > Input:focus {
    border: solid #58a6ff;
}

ModelEditDialog Container > Select {
    margin: 1 0;
    background: #0d1117;
    color: #e6edf3;
    border: solid #30363d;
}

ModelEditDialog Container > Horizontal {
    height: auto;
    margin-top: 1;
    align: center middle;
}

ModelEditDialog Container > Horizontal > Button {
    margin: 0 1;
    background: #21262d;
    color: #e6edf3;
    border: solid #30363d;
}

ModelEditDialog Container > Horizontal > Button:hover {
    background: #30363d;
}

ModelEditDialog Container > Horizontal > Button:focus {
    background: #58a6ff;
}
