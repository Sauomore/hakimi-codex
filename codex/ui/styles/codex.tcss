/* Hakimi Codex - Modern dark theme */

Screen {
    background: #0d1117;
}

MainScreen {
    layout: vertical;
    width: 100%;
    height: 100%;
    background: #0d1117;
}

#main_layout {
    width: 100%;
    height: 1fr;
}

#left_sidebar {
    width: 30;
    height: 100%;
    background: #161b22;
    color: #c9d1d9;
    border-right: solid #30363d;
    padding: 1 1;
}

#left_sidebar .sidebar_title {
    color: #58a6ff;
    text-style: bold;
    height: auto;
    margin-top: 1;
    margin-bottom: 0;
}

#left_sidebar Static {
    height: auto;
    color: #8b949e;
}

#center_panel {
    width: 1fr;
    height: 100%;
    layout: vertical;
}

#messages_log {
    width: 100%;
    height: 1fr;
    background: #0d1117;
    color: #e6edf3;
    border: none;
    padding: 0 1;
}

#messages_log:focus {
    border: none;
}

#streaming_output {
    width: 100%;
    height: auto;
    max-height: 5;
    background: #161b22;
    color: #e6edf3;
    border-top: solid #30363d;
    padding: 0 1;
    display: none;
}

#bottom_panel {
    height: 15;
    background: #161b22;
    border-top: solid #30363d;
    padding: 0 1;
}

#bottom_panel_title {
    height: 1;
    color: #58a6ff;
    text-style: bold;
}

#tool_result_log {
    width: 100%;
    height: 1fr;
    background: #0d1117;
    color: #e6edf3;
    border: solid #30363d;
    padding: 0 1;
    overflow: auto scroll;
    scrollbar-size: 1 1;
}

#tool_result_log:focus {
    border: solid #58a6ff;
}

#input_container {
    height: auto;
    background: #161b22;
    border-top: solid #30363d;
    padding: 0 1;
}

#input_row {
    height: auto;
    min-height: 3;
    max-height: 8;
}

#chat_input {
    width: 1fr;
    height: auto;
    min-height: 3;
    max-height: 8;
    background: #0d1117;
    color: #e6edf3;
    border: solid #30363d;
    padding: 0 1;
}

#chat_input:focus {
    border: solid #58a6ff;
}

#send_button {
    width: 10;
    height: 3;
    background: #238636;
    color: #ffffff;
    border: none;
    text-style: bold;
    content-align: center middle;
}

#send_button:hover {
    background: #2ea043;
}

#send_button:focus {
    background: #2ea043;
}

#input_hint {
    height: 1;
    color: #6e7681;
    background: #161b22;
    padding: 0 2;
}

ModelEditDialog {
    align: center middle;
    background: #0d1117 80%;
}

ModelEditDialog > Container {
    width: 80;
    height: auto;
    border: solid #30363d;
    background: #161b22;
    padding: 1 2;
}

ModelEditDialog Container > Static.title {
    text-align: center;
    color: #58a6ff;
    height: 1;
    margin-bottom: 1;
}

ModelEditDialog Container > Input {
    margin: 1 0;
    background: #0d1117;
    color: #e6edf3;
    border: solid #30363d;
}

ModelEditDialog Container > Input:focus {
    border: solid #58a6ff;
}

ModelEditDialog Container > Select {
    margin: 1 0;
    background: #0d1117;
    color: #e6edf3;
    border: solid #30363d;
}

ModelEditDialog Container > Horizontal {
    height: auto;
    margin-top: 1;
    align: center middle;
}

ModelEditDialog Container > Horizontal > Button {
    margin: 0 1;
    background: #21262d;
    color: #c9d1d9;
    border: solid #30363d;
}

ModelEditDialog Container > Horizontal > Button:hover {
    background: #30363d;
}

ModelEditDialog Container > Horizontal > Button:focus {
    background: #58a6ff;
}

ConfirmationDialog {
    align: center middle;
    background: #0d1117 80%;
}

ConfirmationDialog > Container {
    width: 90;
    height: auto;
    max-height: 90%;
    border: solid #30363d;
    background: #161b22;
    padding: 1 2;
}

ConfirmationDialog Container > Static.title {
    text-align: center;
    color: #58a6ff;
    height: auto;
    margin-bottom: 1;
}

ConfirmationDialog Container > Static.message {
    height: auto;
    margin-bottom: 1;
    color: #e6edf3;
}

ConfirmationDialog Container > RichLog.content {
    height: 1fr;
    min-height: 5;
    max-height: 30;
    border: solid #30363d;
    background: #0d1117;
    margin-bottom: 1;
}

ConfirmationDialog Container > Horizontal {
    height: auto;
    margin-top: 1;
    align: center middle;
}

ConfirmationDialog Container > Horizontal > Button {
    margin: 0 1;
    background: #21262d;
    color: #c9d1d9;
    border: solid #30363d;
}

ConfirmationDialog Container > Horizontal > Button:hover {
    background: #30363d;
}

ConfirmationDialog Container > Horizontal > Button:focus {
    background: #58a6ff;
}

CopyViewDialog {
    align: center middle;
    background: #0d1117 80%;
}

CopyViewDialog > Vertical {
    width: 100;
    height: 80%;
    border: solid #30363d;
    background: #161b22;
    padding: 1 2;
}

CopyViewDialog Vertical > Static.title {
    text-align: center;
    color: #58a6ff;
    height: auto;
    margin-bottom: 1;
}

CopyViewDialog Vertical > Static.hint {
    height: auto;
    color: #d29922;
    text-style: italic;
    margin-bottom: 1;
}

CopyViewDialog Vertical > TextArea {
    height: 1fr;
    border: solid #30363d;
    background: #0d1117;
    color: #e6edf3;
}

CopyViewDialog Vertical > Static#copy_status {
    height: auto;
    margin-top: 1;
    text-align: center;
}

CopyViewDialog Vertical > Horizontal#copy_dialog_buttons {
    height: auto;
    margin-top: 1;
    align: center middle;
}

CopyViewDialog Vertical > Horizontal#copy_dialog_buttons > Button {
    margin: 0 1;
    background: #238636;
    color: #ffffff;
    border: none;
    content-align: center middle;
}

CopyViewDialog Vertical > Horizontal#copy_dialog_buttons > Button:hover {
    background: #2ea043;
}

CopyViewDialog Vertical > Horizontal#copy_dialog_buttons > Button:focus {
    background: #2ea043;
}

CopyViewDialog Vertical > Horizontal#copy_dialog_buttons > Button#copy_close_button {
    background: #21262d;
    color: #c9d1d9;
    border: solid #30363d;
}

CopyViewDialog Vertical > Horizontal#copy_dialog_buttons > Button#copy_close_button:hover {
    background: #30363d;
}

CopyViewDialog Vertical > Horizontal#copy_dialog_buttons > Button#copy_close_button:focus {
    background: #58a6ff;
}
