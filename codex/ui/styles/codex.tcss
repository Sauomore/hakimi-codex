/* Hakimi Codex - High contrast dark theme */

Screen {
    background: #0a0a0a;
}

MainScreen {
    layout: vertical;
    width: 100%;
    height: 100%;
    background: #0a0a0a;
}

#main_layout {
    width: 100%;
    height: 1fr;
}

#left_sidebar {
    width: 28;
    height: 100%;
    background: #111111;
    color: #cccccc;
    border-right: solid #333333;
    padding: 1 1;
}

#left_sidebar .sidebar_title {
    color: #4da6ff;
    text-style: bold;
    height: auto;
    margin-top: 1;
    margin-bottom: 0;
}

#left_sidebar Static {
    height: auto;
    color: #aaaaaa;
}

#center_panel {
    width: 1fr;
    height: 100%;
}

#messages_log {
    width: 100%;
    height: 100%;
    background: #0a0a0a;
    color: #f0f0f0;
    border: none;
    padding: 0 1;
}

#bottom_panel {
    height: 8;
    background: #141414;
    border-top: solid #333333;
    padding: 0 1;
}

#bottom_panel_title {
    height: 1;
    color: #4da6ff;
    text-style: bold;
}

#tool_result_log {
    width: 100%;
    height: 1fr;
    background: #141414;
    color: #f0f0f0;
    border: none;
    padding: 0 1;
}

#input_container {
    height: auto;
    background: #141414;
    border-top: solid #333333;
    padding: 0 1;
}

#input_row {
    height: auto;
    min-height: 3;
    max-height: 8;
}

#chat_input {
    width: 1fr;
    height: auto;
    min-height: 3;
    max-height: 8;
    background: #141414;
    color: #f0f0f0;
    border: none;
    padding: 0 1;
}

#chat_input:focus {
    border: none;
}

#send_button {
    width: 10;
    height: 3;
    background: #4da6ff;
    color: #0a0a0a;
    border: none;
    text-style: bold;
    content-align: center middle;
}

#send_button:hover {
    background: #66b3ff;
}

#send_button:focus {
    background: #66b3ff;
}

#input_hint {
    height: 1;
    color: #888888;
    background: #141414;
    padding: 0 2;
}

ModelEditDialog {
    align: center middle;
    background: #0a0a0a 80%;
}

ModelEditDialog > Container {
    width: 80;
    height: auto;
    border: solid #333333;
    background: #141414;
    padding: 1 2;
}

ModelEditDialog Container > Static.title {
    text-align: center;
    color: #4da6ff;
    height: 1;
    margin-bottom: 1;
}

ModelEditDialog Container > Input {
    margin: 1 0;
    background: #0a0a0a;
    color: #f0f0f0;
    border: solid #333333;
}

ModelEditDialog Container > Input:focus {
    border: solid #4da6ff;
}

ModelEditDialog Container > Select {
    margin: 1 0;
    background: #0a0a0a;
    color: #f0f0f0;
    border: solid #333333;
}

ModelEditDialog Container > Horizontal {
    height: auto;
    margin-top: 1;
    align: center middle;
}

ModelEditDialog Container > Horizontal > Button {
    margin: 0 1;
    background: #1f1f1f;
    color: #f0f0f0;
    border: solid #333333;
}

ModelEditDialog Container > Horizontal > Button:hover {
    background: #333333;
}

ModelEditDialog Container > Horizontal > Button:focus {
    background: #4da6ff;
}

ConfirmationDialog {
    align: center middle;
    background: #0a0a0a 80%;
}

ConfirmationDialog > Container {
    width: 90;
    height: auto;
    max-height: 90%;
    border: solid #333333;
    background: #141414;
    padding: 1 2;
}

ConfirmationDialog Container > Static.title {
    text-align: center;
    color: #4da6ff;
    height: auto;
    margin-bottom: 1;
}

ConfirmationDialog Container > Static.message {
    height: auto;
    margin-bottom: 1;
    color: #f0f0f0;
}

ConfirmationDialog Container > RichLog.content {
    height: 1fr;
    min-height: 5;
    max-height: 30;
    border: solid #333333;
    background: #0a0a0a;
    margin-bottom: 1;
}

ConfirmationDialog Container > Horizontal {
    height: auto;
    margin-top: 1;
    align: center middle;
}

ConfirmationDialog Container > Horizontal > Button {
    margin: 0 1;
    background: #1f1f1f;
    color: #f0f0f0;
    border: solid #333333;
}

ConfirmationDialog Container > Horizontal > Button:hover {
    background: #333333;
}

ConfirmationDialog Container > Horizontal > Button:focus {
    background: #4da6ff;
}
